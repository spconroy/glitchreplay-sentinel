{
  "name": "sitemap-sentinel",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop QA workflow for website page review and GitHub issue reporting.",
  "license": "MIT",
  "homepage": "https://glitchreplay.com/sentinel",
  "repository": {
    "type": "git",
    "url": "https://github.com/spconroy/glitchreplay-sentinel.git"
  },
  "main": "src/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "tsc --noEmit && vite build",
    "start": "electron .",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "fast-xml-parser": "^5.3.2",
    "lucide-react": "^0.555.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "electron": "^39.2.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "wait-on": "^9.0.3"
  }
}
